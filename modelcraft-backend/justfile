# 运行单元测试
[doc("Run Go unit tests")]
test-unit:
    echo "🧪 运行单元测试..."
    rtk go test -v -race -timeout=5m -coverprofile=coverage.out ./...
    echo "✅ 测试完成"

# 运行测试并生成覆盖率报告
[doc("Run tests with coverage report")]
test-unit-coverage:
    echo "🧪 运行单元测试并生成覆盖率报告..."
    rtk go test -v -race -timeout=5m -coverprofile=coverage.out -covermode=atomic ./...
    go tool cover -html=coverage.out -o coverage.html
    echo "✅ 测试完成，覆盖率报告已生成 coverage.html"
    go tool cover -func=coverage.out | grep total | awk '{print "📊 总覆盖率: " $3}'

# 测试指定包
[doc("Run tests for specific package")]
test-unit-pkg pkg:
    #!/usr/bin/env bash
    if [ -z "{{pkg}}" ]; then
        echo "❌ 请指定包路径，例如: just test-unit-pkg ./internal/domain/project"
        exit 1
    fi
    echo "🧪 测试包: {{pkg}}"
    rtk go test -v -race -timeout=5m {{pkg}}

# 清理测试缓存
[doc("Clean test cache and coverage files")]
test-unit-clean:
    echo "🧹 清理测试缓存和覆盖率文件..."
    go clean -testcache
    rm -f coverage.out coverage.html coverage-badge.svg
    echo "✅ 清理完成"

