            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            just deploy-all stop
            sleep 2
            just deploy-all
            ;;
        *)
            echo "❌ Invalid action: {{action}}"
            exit 1
            ;;
    esac

# ========================
