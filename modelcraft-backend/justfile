# 列出所有环境
[doc("List all environment files (.env.A, .env.B, .env.C, etc.)")]
env-list:
    #!/usr/bin/env bash
    echo "📋 Available environment files:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    for file in .env.*; do
        if [ -f "$file" ]; then
            env_name=$(echo "$file" | sed 's/.env.//')
            echo "  📄 $env_name ($file)"
        fi
    done
    if [ -f ".env.example" ]; then
        echo "  📄 example (.env.example)"
    fi
    echo ""
    if [ ! -f ".env" ]; then
        echo "⚠️  No .env file found (no environment is active)"
        echo "💡 Use 'just env-create <name>' to create a new environment"
    else
        echo "💡 Current active environment: just env-current"
    fi

# 创建新环境
[doc("Create a new environment file from template")]
env-create name template="":
    #!/usr/bin/env bash
    if [ -z "{{name}}" ]; then
        echo "❌ Please specify environment name."
        echo ""
        echo "Usage: just env-create <name> [template=<template_file>]"
        echo ""
        echo "Examples:"
        echo "  just env-create dev                              # Create .env.dev from .env.dev.example"
        echo "  just env-create prod template=.env.dev.example   # Create .env.prod from .env.dev.example"
        echo ""
        echo "Available templates:"
        for file in .env.*.example; do
            if [ -f "$file" ]; then
                echo "  - $file"
            fi
        done
        exit 1
    fi
    
    ENV_FILE=".env.{{name}}"
    
    # Determine template file
    if [ -n "{{template}}" ]; then
        TEMPLATE_FILE="{{template}}"
    else
        # Default template is .env.dev.example
        TEMPLATE_FILE=".env.dev.example"
    fi
    
    # Check if target already exists
    if [ -f "$ENV_FILE" ]; then
        echo "⚠️  Environment file already exists: $ENV_FILE"
        echo ""
        echo "💡 Use 'just env-switch {{name}}' to switch to this environment."
        echo "   Or delete $ENV_FILE first if you want to recreate it."
        exit 1
    fi
    
    # Check template exists
    if [ ! -f "$TEMPLATE_FILE" ]; then
        echo "❌ Template file not found: $TEMPLATE_FILE"
        echo ""
        echo "Available templates:"
        for file in .env.*.example; do
            if [ -f "$file" ]; then
                echo "  - $file"
            fi
        done
        exit 1
    fi
    
    echo "📝 Creating new environment: {{name}}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   Template: $TEMPLATE_FILE"
    echo "   Target:   $ENV_FILE"
    echo ""
    
    # Copy template to new env file
    cp "$TEMPLATE_FILE" "$ENV_FILE"
    
    echo "✅ Environment file created: $ENV_FILE"
    echo ""
    echo "💡 Next steps:"
    echo "   1. Edit $ENV_FILE to configure your environment"
    echo "   2. Run 'just env-switch {{name}}' to activate it"

# 显示当前环境
[doc("Show currently active environment")]
env-current:
    #!/usr/bin/env bash
    if [ ! -e ".env" ]; then
        echo "⚠️  No .env file found. No environment is active."
        echo ""
        echo "💡 Use 'just env-switch <env>' to activate an environment."
        exit 0
    fi
    
    echo "🔍 Checking current environment..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    # Check if .env is a symlink
    if [ -L ".env" ]; then
        target=$(readlink .env)
        if [[ "$target" == .env.* ]]; then
            env_name=$(echo "$target" | sed 's/.env.//')
            echo "✅ Current environment: $env_name"
            echo "   Link: .env → $target"
        else
            echo "✅ Current environment: custom"
            echo "   Link: .env → $target"
        fi
    else
        echo "📝 .env is a regular file (not a symlink)."
        echo "   This may have been created manually or with the old copy method."
        echo ""
        echo "💡 To convert to symlink mode, use: just env-switch <env>"
    fi
    
    echo ""
    echo "📄 .env file info:"
    ls -lh .env | awk '{print "   " $0}'

# 切换环境
[doc("Switch to a different environment")]
env-switch name create="":
    #!/usr/bin/env bash
    if [ -z "{{name}}" ]; then
        echo "❌ Please specify environment name."
        echo ""
        echo "Usage: just env-switch <env_name> [create=true]"
        echo ""
        echo "Options:"
        echo "  name        Environment name to switch to"
        echo "  create=true Auto-create from template if not exists"
        echo ""
        echo "Available environments:"
        for file in .env.*; do
            if [ -f "$file" ] && [[ "$file" != *.example ]]; then
                env_name=$(echo "$file" | sed 's/.env.//')
                echo "  - $env_name"
            fi
        done
        exit 1
    fi
    
    ENV_FILE=".env.{{name}}"
    
    if [ ! -f "$ENV_FILE" ]; then
        echo "⚠️  Environment file not found: $ENV_FILE"
        echo ""
        
        # Check if CREATE flag is set
        if [ "{{create}}" = "true" ] || [ "{{create}}" = "1" ]; then
            # Try to find a suitable template (default: .env.dev.example)
            TEMPLATE=""
            if [ -f ".env.dev.example" ]; then
                TEMPLATE=".env.dev.example"
            fi
            
            if [ -n "$TEMPLATE" ]; then
                echo "📝 Creating environment from template: $TEMPLATE"
                cp "$TEMPLATE" "$ENV_FILE"
                echo "✅ Created: $ENV_FILE"
                echo ""
            else
                echo "❌ No template found to create environment."
                echo "   Please create .env.dev.example first."
                exit 1
            fi
        else
            echo "Available environments:"
            for file in .env.*; do
                if [ -f "$file" ] && [[ "$file" != *.example ]]; then
                    env_name=$(echo "$file" | sed 's/.env.//')
                    echo "  - $env_name"
                fi
            done
            echo ""
            echo "💡 To create this environment from template, run:"
            echo "   just env-switch {{name}} create=true"
            echo ""
            echo "   Or create manually with:"
            echo "   just env-create {{name}}"
            exit 1
        fi
    fi
    
    echo "🔄 Switching environment to: {{name}}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    # Show current state
    if [ -L ".env" ]; then
        current_target=$(readlink .env)
        echo "📌 Current: .env → $current_target"
    elif [ -f ".env" ]; then
        echo "📌 Current: .env (regular file)"
    fi
    
    # Remove existing .env (works for both symlink and regular file)
    rm -f .env
    
    # Create symlink
    ln -s "$ENV_FILE" .env
    
    echo "✅ Environment switched to: {{name}}"
    echo "   Link: .env → $ENV_FILE"
    echo ""
    echo "💡 The new environment is now active."
    echo "   Use 'just env-current' to verify."

# 对比环境差异
[doc("Show differences between current .env and another")]
env-diff name:
    #!/usr/bin/env bash
    if [ -z "{{name}}" ]; then
        echo "❌ Please specify environment name."
        echo "Usage: just env-diff <env_name>"
        exit 1
    fi
    
    ENV_FILE=".env.{{name}}"
    
    if [ ! -f "$ENV_FILE" ]; then
        echo "❌ Environment file not found: $ENV_FILE"
        exit 1
    fi
    
    if [ ! -f ".env" ]; then
        echo "⚠️  No .env file found."
        exit 1
    fi
    
    echo "📊 Differences between .env and $ENV_FILE:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    diff -u --color=always "$ENV_FILE" .env || true
    echo ""
    echo "💡 Lines starting with '-' are in $ENV_FILE but not in .env"
    echo "   Lines starting with '+' are in .env but not in $ENV_FILE"

# 备份环境
[doc("Create a backup of current .env file")]
env-backup:
    #!/usr/bin/env bash
    if [ ! -f ".env" ]; then
        echo "❌ No .env file found to backup."
        exit 1
    fi
    
    BACKUP=".env.backup.$(date +%Y%m%d_%H%M%S)"
    cp .env "$BACKUP"
    echo "✅ Backup created: $BACKUP"

# 恢复环境
[doc("Restore .env from a backup file")]
env-restore file="":
    #!/usr/bin/env bash
    if [ -z "{{file}}" ]; then
        echo "❌ Please specify backup file."
        echo ""
        echo "Available backups:"
        ls -lht .env.backup.* 2>/dev/null || echo "  No backups found."
        exit 1
    fi
    
    if [ ! -f "{{file}}" ]; then
        echo "❌ Backup file not found: {{file}}"
        exit 1
    fi
    
    cp "{{file}}" .env
    echo "✅ Restored .env from {{file}}"
