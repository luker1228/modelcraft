# 杀掉指定端口的进程
[doc("Kill process on specified port")]
port-kill port="8080":
    #!/usr/bin/env bash
    echo "🔪 Killing process on port {{port}}..."
    lsof -ti:{{port}} | xargs kill -9 2>/dev/null || fuser -k {{port}}/tcp 2>/dev/null || echo "Port {{port}} is already free"
    echo "✅ Port {{port}} is now free"

# 检查端口占用
[doc("Check what's using specified port")]
port-check port="8080":
    #!/usr/bin/env bash
    echo "🔍 Checking port {{port}}..."
    lsof -i:{{port}} || echo "Port {{port}} is free"

