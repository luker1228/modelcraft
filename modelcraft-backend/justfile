# 管理基础设施 (MySQL, Redis)
[doc("Manage infrastructure: start|status|stop|restart")]
deploy-infra action="start":
    #!/usr/bin/env bash
    set -e
    
    show_env() {
        if [ -L ".env" ]; then
            ENV_TARGET=$(readlink .env)
            ENV_NAME=$(echo "$ENV_TARGET" | sed 's/.env.//')
            echo "📌 Environment: $ENV_NAME"
        elif [ -f ".env" ]; then
            echo "📌 Environment: .env (regular file)"
        else
            echo "❌ No .env file found. Run: just env-switch <name>"
            exit 1
        fi
    }
    
    case "{{action}}" in
        start)
            echo "🚀 Starting Infrastructure Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            show_env
            echo ""
            echo "📦 Starting MySQL, Redis..."
            docker-compose -f docker-compose.local.yml up -d
            echo ""
            echo "⏳ Waiting for services to be healthy..."
            sleep 8
            echo ""
            docker-compose -f docker-compose.local.yml ps
            echo ""
            echo "✅ Infrastructure services are running"
            echo "   MySQL - localhost:3307"
            echo "   Redis - localhost:6379"
            ;;
        status)
            echo "📊 Infrastructure Status"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            show_env
            echo ""
            echo "🐳 Docker Services:"
            docker-compose -f docker-compose.local.yml ps 2>/dev/null || echo "   No services running"
            ;;
        stop)
            echo "🛑 Stopping Infrastructure Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            docker-compose -f docker-compose.local.yml down || true
            echo "✅ Infrastructure services stopped"
            ;;
        restart)
            echo "🔄 Restarting Infrastructure Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            docker-compose -f docker-compose.local.yml down || true
            sleep 2
            docker-compose -f docker-compose.local.yml up -d
            echo "⏳ Waiting for services..."
            sleep 8
            docker-compose -f docker-compose.local.yml ps
            echo "✅ Infrastructure services restarted"
            ;;
        *)
            echo "❌ Invalid action: {{action}}"
            echo "   Valid actions: start, status, stop, restart"
            exit 1
            ;;
    esac

# 管理应用服务
[doc("Manage application services: start|status|stop|restart")]
deploy-app action="start":
    #!/usr/bin/env bash
    set -e
    
    show_env() {
        if [ -L ".env" ]; then
            ENV_TARGET=$(readlink .env)
            ENV_NAME=$(echo "$ENV_TARGET" | sed 's/.env.//')
            echo "📌 Environment: $ENV_NAME"
        elif [ -f ".env" ]; then
            echo "📌 Environment: .env (regular file)"
        else
            echo "❌ No .env file found. Run: just env-switch <name>"
            exit 1
        fi
    }
    
    case "{{action}}" in
        start)
            echo "🚀 Starting Application Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            show_env
            echo ""
            
            # Build and start ModelCraft
            echo ""
            echo "🏗️  Building ModelCraft..."
            just build
            echo ""
            echo "🖥️  Starting ModelCraft server..."
            mkdir -p logs
            nohup go run {{SERVER_PATH}} > logs/server.log 2>&1 &
            echo "   PID: $!"
            sleep 3
            
            # Health check
            if curl -s http://localhost:8080/health > /dev/null 2>&1; then
                echo ""
                echo "✅ Application services are running"
                echo "   ModelCraft - http://localhost:8080"
            else
                echo ""
                echo "⚠️  Server may still be starting, check: just deploy-app status"
            fi
            ;;
        status)
            echo "📊 Application Status"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            show_env
            echo ""
            
            # ModelCraft status
            echo ""
            echo "🖥️  ModelCraft:"
            if pgrep -f "modelcraft" > /dev/null 2>&1 || pgrep -f "go run.*cmd/server" > /dev/null 2>&1; then
                echo "   Status: Running"
                PID=$(pgrep -f "modelcraft" 2>/dev/null || pgrep -f "go run.*cmd/server" 2>/dev/null | head -1)
                echo "   PID: $PID"
                if curl -s http://localhost:8080/health > /dev/null 2>&1; then
                    echo "   Health: OK"
                    echo "   URL: http://localhost:8080"
                else
                    echo "   Health: Not responding"
                fi
            else
                echo "   Status: Not running"
            fi
            ;;
        stop)
            echo "🛑 Stopping Application Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            
            # Stop ModelCraft
            echo "Stopping ModelCraft..."
            pkill -f "go run.*cmd/server/main.go" 2>/dev/null || true
            pkill -f "modelcraft" 2>/dev/null || true
            
            echo "✅ Application services stopped"
            ;;
        restart)
            echo "🔄 Restarting Application Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            
            # Stop
            pkill -f "go run.*cmd/server/main.go" 2>/dev/null || true
            pkill -f "modelcraft" 2>/dev/null || true
            sleep 2
            
            # Start (call self with start action)
            just deploy-app
            ;;
        *)
            echo "❌ Invalid action: {{action}}"
            echo "   Valid actions: start, status, stop, restart"
            exit 1
            ;;
    esac

# 管理所有服务
[doc("Manage all services: start|status|stop|restart")]
deploy-all action="start":
    #!/usr/bin/env bash
    set -e
    
    case "{{action}}" in
        start)
            echo "🚀 Starting All Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            just deploy-infra
            echo ""
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            just deploy-app
            echo ""
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "🎯 All services deployed!"
            ;;
        status)
            echo "📊 Full Deployment Status"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            just deploy-infra status
            echo ""
            just deploy-app status
            ;;
        stop)
            echo "🛑 Stopping All Services..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            just deploy-app stop
