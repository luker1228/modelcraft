    echo "🤖 自动补充单元测试..."
    if [ -n "{{package}}" ]; then
        ./scripts/auto-fix-coverage.sh --max-iterations {{max_iterations}} --package {{package}}
    else
        ./scripts/auto-fix-coverage.sh --max-iterations {{max_iterations}}
    fi

