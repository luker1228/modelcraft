# 构建应用
[doc("Build the application")]
build:
    go build -o bin/{{BINARY_NAME}} {{SERVER_PATH}}

# 生产环境构建
[doc("Production build")]
build-prod:
    CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o bin/{{BINARY_NAME}} {{SERVER_PATH}}

# 跨平台构建
[doc("Build for all platforms (Linux, macOS, Windows)")]
build-all:
    #!/usr/bin/env bash
    GOOS=linux GOARCH=amd64 go build -o bin/{{BINARY_NAME}}-linux-amd64 {{SERVER_PATH}}
    GOOS=darwin GOARCH=amd64 go build -o bin/{{BINARY_NAME}}-darwin-amd64 {{SERVER_PATH}}
    GOOS=darwin GOARCH=arm64 go build -o bin/{{BINARY_NAME}}-darwin-arm64 {{SERVER_PATH}}
    GOOS=windows GOARCH=amd64 go build -o bin/{{BINARY_NAME}}-windows-amd64.exe {{SERVER_PATH}}

# 运行应用
[doc("Run the application in background. Use --force or force=true to stop existing processes first")]
run *FLAGS:
    #!/usr/bin/env bash
    # 解析参数: 支持 --force 和 force=true 两种语法
    FORCE_MODE=false
    for arg in {{FLAGS}}; do
        if [ "$arg" = "--force" ] || [ "$arg" = "force=true" ]; then
            FORCE_MODE=true
            break
        fi
    done
    
    # Force 模式：先停止现有进程
    if [ "$FORCE_MODE" = "true" ]; then
        echo "🔪 Force mode: Stopping existing processes..."
        # 方式 1: 通过端口号查找并杀掉进程
        if lsof -ti:8080 > /dev/null 2>&1; then
            lsof -ti:8080 | xargs kill -9 2>/dev/null || fuser -k 8080/tcp 2>/dev/null
            echo "✅ Stopped process on port 8080"
        fi
        # 方式 2: 杀掉匹配的 go run 进程
        if pgrep -f "go run.*cmd/server" > /dev/null; then
            pkill -9 -f "go run.*cmd/server"
            echo "✅ Stopped go run processes"
        fi
        # 方式 3: 杀掉二进制文件进程
        pkill -f "^"{{BINARY_NAME}} 2>/dev/null && echo "✅ Stopped {{BINARY_NAME}} binary"
        sleep 1
    fi
    
    echo "🚀 Starting application..."
    mkdir -p logs
    echo "📝 Log output: logs/server.log"
    nohup sh -c "LOG_OUTPUT_PATH=logs/server.log go run {{SERVER_PATH}}" > logs/server.log 2>&1 &
    PID=$!
    echo "✅ Application started in background"
    echo "   PID: $PID"
    sleep 2
    if ps -p $PID > /dev/null; then
        echo "✅ Process is running"
    else
        echo "⚠️  Process may have exited, check logs/server.log"
    fi

# 停止服务
[doc("Stop background server")]
stop:
    #!/usr/bin/env bash
    echo "🛑 正在停止服务..."
    if lsof -ti:8080 > /dev/null 2>&1; then
        lsof -ti:8080 | xargs kill -9 2>/dev/null || fuser -k 8080/tcp 2>/dev/null
        echo "✅ 服务已停止 (端口 8080)"
    else
        echo "ℹ️  端口 8080 上没有运行的进程"
    fi

# 热重载开发模式
[doc("Run with hot reload (requires Air)")]
dev:
    air -c .air.toml

# 重启服务
[doc("Restart server")]
restart: stop build run

# 查看服务状态
[doc("Check server status")]
status:
    #!/usr/bin/env bash
    echo "🔍 检查服务状态..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    # 主要判断依据: 健康检查接口
    if curl -sf http://localhost:8080/health > /dev/null 2>&1; then
        echo "✅ 服务正在运行"
        echo ""
        
        # 显示进程信息
        if pgrep -f "go run.*cmd/server" > /dev/null 2>&1; then
            PID=$(pgrep -f "go run.*cmd/server" | head -1)
            echo "📋 进程信息:"
            echo "   类型: go run (开发模式)"
            echo "   PID: $PID"
        elif pgrep -f {{BINARY_NAME}} > /dev/null 2>&1; then
            PID=$(pgrep -f {{BINARY_NAME}} | head -1)
            echo "📋 进程信息:"
            echo "   类型: 二进制文件"
            echo "   PID: $PID"
        fi
        
        # 显示端口信息
        if lsof -i:8080 > /dev/null 2>&1; then
            echo ""
            echo "🌐 端口: 8080 (正在监听)"
        fi
        
        # 健康检查详情
        echo ""
        echo "🏥 健康检查: ✅ 通过"
        echo "   URL: http://localhost:8080/health"
        
    else
        echo "❌ 服务未运行"
        echo ""
        
        # 检查是否有进程但健康检查失败
        if pgrep -f "go run.*cmd/server" > /dev/null 2>&1 || pgrep -f {{BINARY_NAME}} > /dev/null 2>&1; then
            echo "⚠️  发现进程但健康检查失败，服务可能正在启动或异常"
            if pgrep -f "go run.*cmd/server" > /dev/null 2>&1; then
                PID=$(pgrep -f "go run.*cmd/server" | head -1)
                echo "   PID: $PID"
            fi
            echo ""
            echo "💡 建议:"
            echo "   - 重启服务: just run --force"
        else
            echo "💡 启动服务: just run"
        fi
    fi

# 清理构建产物
