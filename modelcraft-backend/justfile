# 统一数据库管理命令
[doc("Database management: create|drop|up|down|status|reset|lint|diff|login")]
db action="up" env_file=".env" print_sql="0":
    #!/usr/bin/env bash
    set -e
    
    # 确保 atlas 已安装
    ensure_atlas() {
        if ! command -v atlas > /dev/null 2>&1; then
            echo "atlas 未安装，正在安装..."
            curl -sSf https://atlasgo.sh | sh
        fi
    }
    
    source scripts/db-env.sh "{{env_file}}"
    
    case "{{action}}" in
        create)
            echo "🗄️  Creating database if not exists: ${DB_NAME}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME};"
            mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME}_dev;"
            echo "✅ Database ${DB_NAME} is ready"
            ;;
        drop)
            echo "⚠️  Dropping database: ${DB_NAME}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -e "DROP DATABASE IF EXISTS ${DB_NAME};"
            echo "✅ Database ${DB_NAME} dropped successfully"
            ;;
        up)
            ensure_atlas
            # 先确保数据库存在
            mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME};" 2>/dev/null || true
            mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME}_dev;" 2>/dev/null || true
            
            echo "🗄️  Applying schema..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "📋 Database Connection Info:"
            echo "   - DB_URL: ${DB_URL}"
            echo "   - DB_DEV_URL: ${DB_DEV_URL}"
            echo "   - Schema Dir: db/schema/mysql/"
            echo ""
            echo "📂 Schema files to apply:"
            ls -1 db/schema/mysql/*.sql | while read file; do
                echo "   - $(basename $file)"
            done
            echo ""
            atlas schema apply -u "${DB_URL}" --to file://db/schema/mysql/ --dev-url "${DB_DEV_URL}" --auto-approve
            echo ""
            echo "✅ Schema apply completed"
            ;;
        down)
            echo "⚠️  Manual rollback required"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "Review migration files in db/migrations/"
            ;;
        status)
            echo "🗄️  Database Status"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "📋 Connection: ${DB_USER}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
            echo ""
            
            # 检查数据库是否存在
            if mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -e "USE ${DB_NAME};" 2>/dev/null; then
                echo "✅ Database exists: ${DB_NAME}"
                echo ""
                echo "📊 Tables:"
                mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" -N -e "
                    SELECT CONCAT('   ', table_name, ' (', table_rows, ' rows)')
                    FROM information_schema.tables 
                    WHERE table_schema = '${DB_NAME}' 
                    ORDER BY table_name;" 2>/dev/null
                echo ""
                echo "📈 Schema files (db/schema/mysql/):"
                ls -1 db/schema/mysql/*.sql 2>/dev/null | while read file; do
                    echo "   - $(basename $file)"
                done
            else
                echo "❌ Database does not exist: ${DB_NAME}"
                echo ""
                echo "💡 Run 'just db create' to create the database"
            fi
            ;;
        reset)
            ensure_atlas
            echo "⚠️  Resetting database (drop and recreate)!"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            atlas schema clean -u "${DB_URL}" --auto-approve
            just db up {{env_file}}
            ;;
        lint)
            ensure_atlas
            echo "🗄️  Linting migrations..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            atlas migrate lint --dir file://db/migrations/ --dev-url "${DB_DEV_URL}"
            ;;
        diff)
            ensure_atlas
            echo "🗄️  Creating migration diff..."
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            cd db
            atlas migrate diff initial --to file://schema/ --dev-url "${DB_DEV_URL}"
            ;;
        login)
            if command -v mysql > /dev/null 2>&1; then
                mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" "${DB_NAME}"
                exit 0
            fi
            echo "⚠️  mysql client not found on host."
            echo "You can install it (e.g. apt-get install mysql-client) or use docker exec:"
            echo "  docker exec -it modelcraft-mysql-local mysql -h \"${DB_HOST}\" -P \"${DB_PORT}\" -u \"${DB_USER}\" \"-p\${DB_PASSWORD}\" \"${DB_NAME}\""
            exit 1
            ;;
        *)
            echo "❌ Invalid action: {{action}}"
            echo ""
            echo "Usage: just db <action> [env_file=.env]"
            echo ""
            echo "Actions:"
            echo "  create  - Create database if not exists"
            echo "  drop    - Drop database"
            echo "  up      - Apply migrations (default)"
            echo "  down    - Rollback last migration"
            echo "  status  - Check migration status"
            echo "  reset   - Reset database (drop and recreate)"
            echo "  lint    - Lint migrations"
            echo "  diff    - Create new migration diff"
            echo "  login   - Login to database"
            echo ""
            echo "Examples:"
            echo "  just db              # Apply migrations (default)"
            echo "  just db up           # Apply migrations"
            echo "  just db status       # Check migration status"
            echo "  just db reset        # Reset database"
            echo "  just db login        # Login to database"
            exit 1
            ;;
    esac

[doc("Merge db/schema/mysql/*.sql into a single file")]
db-merge-schema output="db/schema/merged/mysql_schema.sql":
    ./scripts/merge-schema-sql.sh "{{output}}"

