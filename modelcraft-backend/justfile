      --package-path "{{package_path}}" \
      --interface-name "{{interface_name}}" \
      --output-file "{{output_file}}" \
      --wrapper-name "{{wrapper_name}}" \
      --constructor-name "{{constructor_name}}" \
      --delegate-type "{{delegate_type}}"
    echo "✅ Safe querier 生成完成"

