# 运行 linter
[doc("Run linter")]
lint: install-golangci-lint
    mkdir -p .cache/golangci-lint .cache/go-build
    echo "🔎 预检查：Repository 构造函数必须使用 dbgenwrap.NewSafeQuerier(q)..."
    ! rg -n --multiline --multiline-dotall --pcre2 '^func\s+NewSql\w*Repository\s*\(q\s+dbgen\.Querier\).*?return\s+&\w+\{q:\s*q\}' internal/infrastructure --glob '*.go'
    echo "🔎 预检查：WithTx 回调必须使用 tx Querier 且不得在回调内调用非 tx repo..."
    ./scripts/check-withtx-repo-usage.sh
    echo "🔍 运行 golangci-lint 代码检查..."
    GOLANGCI_LINT_CACHE="$(pwd)/.cache/golangci-lint" GOCACHE="$(pwd)/.cache/go-build" golangci-lint run

# 运行 linter 并自动修复
[doc("Run linter with auto-fix")]
lint-fix: install-golangci-lint
    mkdir -p .cache/golangci-lint .cache/go-build
    echo "🔎 预检查：Repository 构造函数必须使用 dbgenwrap.NewSafeQuerier(q)..."
    ! rg -n --multiline --multiline-dotall --pcre2 '^func\s+NewSql\w*Repository\s*\(q\s+dbgen\.Querier\).*?return\s+&\w+\{q:\s*q\}' internal/infrastructure --glob '*.go'
    echo "🔎 预检查：WithTx 回调必须使用 tx Querier 且不得在回调内调用非 tx repo..."
    ./scripts/check-withtx-repo-usage.sh
    echo "运行 golangci-lint 代码检查并自动修复..."
    GOLANGCI_LINT_CACHE="$(pwd)/.cache/golangci-lint" GOCACHE="$(pwd)/.cache/go-build" golangci-lint run --fix

