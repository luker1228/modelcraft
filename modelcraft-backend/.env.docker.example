# ModelCraft Docker Deployment Environment Configuration Template
# Use this file as a reference for docker-compose .env file
# Copy values to your .env file in project root (docker-compose auto-loads it)

# ============================================
# Server Configuration
# ============================================
GIN_MODE=release  # Use 'release' for production, 'debug' for development
PORT=8080

# ============================================
# Database Configuration
# ============================================
# For Docker Compose with internal MySQL service
DB_HOST=modelcraft-mysql  # Docker Compose service name
DB_PORT=3306
DB_USERNAME=modelcraft
DB_PASSWORD=your_secure_db_password_here  # REQUIRED: Generate a strong password
DB_DATABASE=modelcraft
DB_CHARSET=utf8mb4
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=3600
DB_LOG_LEVEL=info
DB_MIGRATE_ON_STARTUP=true

# For external MySQL (if using external database)
# DB_HOST=your-mysql-host.example.com
# DB_PORT=3306
# DB_USERNAME=your_mysql_user
# DB_PASSWORD=your_mysql_password
# DB_DATABASE=modelcraft

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=modelcraft-redis  # Docker Compose service name
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if Redis has no password

# ============================================
# Security Configuration (REQUIRED)
# ============================================
# JWT signing secret - Generate a random secure value
# Example: openssl rand -base64 64
JWT_SECRET=your_production_jwt_secret_change_this_value

# AES encryption key - MUST be exactly 32 bytes for AES-256
# Example: openssl rand -base64 32 | tr -d '\n' | cut -c1-32
CRYPTO_AES_KEY=12345678901234567890123456789012

# ============================================
# Logger Configuration
# ============================================
LOGGER_LEVEL=info  # debug, info, warn, error
LOGGER_OUTPUT_PATH=stdout  # Use stdout for Docker (logs collected by Docker)
LOGGER_MAX_SIZE=100
LOGGER_MAX_BACKUPS=10
LOGGER_MAX_AGE=7
LOGGER_COMPRESS=true

# ============================================
# Test Configuration
# ============================================
# Application URL for automated tests (used by tests/config.py)
MODELCRAFT_BASE_URL=http://localhost:8080

# Control test data cleanup after automated tests (true/false)
# Set to false to preserve test data for debugging
CLEANUP_ENABLED=true

# ============================================
# Casdoor Authentication Configuration
# ============================================
# Casdoor database configuration
CASDOOR_DB_USERNAME=casdoor
CASDOOR_DB_PASSWORD=casdoor_password  # REQUIRED: Change this!
CASDOOR_DB_NAME=casdoor

# Casdoor OAuth secrets (obtain from Casdoor after setup)
# Steps to get these values:
# 1. Start Casdoor: docker compose up -d casdoor casdoor-db
# 2. Open http://localhost:8000 (login: admin/123)
# 3. Go to Applications → Add → Create application
# 4. Copy the Client ID and Client Secret
CASDOOR_CLIENT_ID=your-client-id-from-casdoor-app
CASDOOR_CLIENT_SECRET=your-client-secret-from-casdoor-app

# NOTE: Non-sensitive Casdoor config (endpoint, organization, application,
# redirect_uri, certificate) should be configured in configs/config.yaml

# ============================================
# Other Configuration
# ============================================
TZ=Asia/Shanghai  # Timezone

# MySQL port mapping (to avoid conflict with host MySQL on 3306)
MYSQL_PORT=6033

# ============================================
# Quick Setup Commands
# ============================================
# Generate secure secrets:
# DB_PASSWORD=$(openssl rand -base64 24)
# JWT_SECRET=$(openssl rand -base64 64)
# CRYPTO_AES_KEY=$(openssl rand -base64 32 | tr -d '\n' | cut -c1-32)
