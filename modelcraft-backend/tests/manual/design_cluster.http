### List Databases in a Project's Cluster
POST http://localhost:8080/org/modelcraft/design/graphql
Content-Type: application/json

{
  "query": "query ListDatabases($input: ListDatabasesInput!) { listDatabases(input: $input) { edges { node { name charset collation size tables } cursor } pageInfo { hasNextPage hasPreviousPage startCursor endCursor } totalCount } }",
  "variables": {
    "input": {
      "projectName": "dev-project",
      "name": "dev-cluster",
      "offset": 0,
      "limit": 20,
      "search": ""
    }
  }
}

