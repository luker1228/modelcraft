# Environment Configuration Template
# Copy this file to create environment-specific configurations:
#   - local.env: For local development environment
#   - docker.env: For Docker Compose environment

# ============================================
# ModelCraft Service Configuration
# ============================================
# URL where ModelCraft service is running
MODELCRAFT_BASE_URL=http://localhost:8080

# ============================================
# Test Database Configuration
# ============================================
# Database connection details for test execution
# These credentials are used for:
# 1. Database connectivity health checks
# 2. Resource cleanup operations
TEST_DB_HOST=localhost
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=your_password_here
TEST_DB_NAME=modelcraft_test

# ============================================
# Test Behavior Configuration
# ============================================
# Control test data cleanup behavior
# - true: Automatically cleanup test data after tests (recommended for CI/CD)
# - false: Preserve test data for debugging (useful during development)
CLEANUP_ENABLED=true

# ============================================
# Test Execution Configuration
# ============================================
# HTTP request timeout in seconds
TEST_TIMEOUT=30

# Number of retries for failed requests
TEST_RETRY_COUNT=3

# ============================================
# Usage Examples
# ============================================
# Test with default environment (local):
#   make test
#
# Test with specific environment:
#   make test ENV=docker
#
# Test without cleanup (override config):
#   make test ENV=local CLEANUP=no
#
# Run cleanup only:
#   make test-cleanup-only ENV=local
