      "--chart-5": "340 75% 55%"
    }
  },
  "shadcn": {
    "style": "new-york",
    "rsc": true,
    "baseColor": "gray",
    "cssVariables": true,
    "iconLibrary": "lucide",
    "components": [
      "alert-dialog", "alert", "avatar", "badge", "breadcrumb", "button",
      "card", "checkbox", "collapsible", "command", "dialog", "drawer",
      "dropdown-menu", "form", "input", "label", "popover", "scroll-area",
      "select", "separator", "sheet", "sidebar", "skeleton", "switch",
      "table", "tabs", "textarea", "toggle", "toggle-group", "tooltip"
    ],
    "customComponents": [
      "connection-config-card", "editor-layout", "editor-sidebar",
      "identity-form-section", "loading-spinner", "search-input", "view-toggle"
    ]
  }
}
