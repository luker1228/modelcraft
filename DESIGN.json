{
  "$schema": "DESIGN.json sidecar — extensions that DESIGN.md YAML frontmatter cannot hold",
  "shadows": {
    "sm": {
      "value": "0 1px 2px rgba(0, 0, 0, 0.05)",
      "usage": "Ambient lift on buttons at rest, subtle surface differentiation"
    },
    "md": {
      "value": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
      "usage": "Popovers, select dropdowns, context menus — floating overlay"
    },
    "lg": {
      "value": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
      "usage": "Dialogs, sheets, alert dialogs — highest elevation"
    }
  },
  "motion": {
    "keyframes": {
      "fade-in": {
        "from": { "opacity": "0", "transform": "translateY(4px)" },
        "to": { "opacity": "1", "transform": "translateY(0)" }
      },
      "slide-in-right": {
        "from": { "opacity": "0", "transform": "translateX(10px)" },
        "to": { "opacity": "1", "transform": "translateX(0)" }
      },
      "accordion-down": {
        "from": { "height": "0" },
        "to": { "height": "var(--radix-accordion-content-height)" }
      },
      "accordion-up": {
        "from": { "height": "var(--radix-accordion-content-height)" },
        "to": { "height": "0" }
      }
    },
    "animations": {
      "fade-in": "fade-in 0.25s ease-out",
      "slide-in-right": "slide-in-right 0.25s ease-out",
      "accordion-down": "accordion-down 0.2s ease-out",
      "accordion-up": "accordion-up 0.2s ease-out"
    },
    "durations": {
      "instant": "0ms",
      "fast": "150ms",
      "normal": "200ms",
      "entrance": "250ms",
      "sheet-close": "300ms",
      "sheet-open": "500ms"
    },
    "easings": {
      "default": "ease-out",
      "sheet": "ease-in-out"
    },
    "rules": {
      "max-entrance-duration": "300ms",
      "composited-only": ["transform", "opacity"],
      "banned-properties": ["width", "height", "left", "right", "top"],
      "no-infinite": true,
      "exceptions": ["accordion (height via Radix)", "skeleton pulse (Tailwind built-in)"]
    }
  },
  "breakpoints": {
    "container": {
      "maxWidth": "1400px",
      "padding": "2rem",
      "center": true
    },
    "screens": {
      "2xl": "1400px"
    }
  },
  "typography": {
    "fonts": {
      "sans": {
        "family": "Inter, system-ui, sans-serif",
        "cssVariable": "--font-inter",
        "weights": [300, 400, 500, 600, 700],
        "display": "swap"
      },
      "heading": {
        "family": "Space Grotesk, system-ui, sans-serif",
        "cssVariable": "--font-space-grotesk",
        "weights": [400, 500, 600, 700],
        "display": "swap"
      },
      "mono": {
        "family": "Fira Code, monospace",
        "cssVariable": "--font-fira-code",
        "weights": [400, 500, 600],
        "display": "swap"
      }
    },
    "weightPolicy": {
      "400": "Body text, form inputs, descriptions (default)",
      "500": "Technical identifiers in font-mono only (code, enum names, API identifiers)",
      "600": "Headings, section labels, table headers, badges",
      "700": "Page-level display headings only (one per view)",
      "banned": [800, 900]
    },
    "scaleMinimum": "0.75rem"
  },
  "borderRadius": {
    "base": "0.5rem",
    "computed": {
      "sm": "calc(var(--radius) - 4px)",
      "md": "calc(var(--radius) - 2px)",
      "lg": "var(--radius)",
      "xl": "calc(var(--radius) + 4px)",
      "2xl": "calc(var(--radius) + 8px)"
    },
    "resolved": {
      "sm": "0.25rem",
      "md": "0.375rem",
      "lg": "0.5rem",
      "xl": "0.75rem",
      "2xl": "1rem"
    }
  },
  "components": {
    "button": {
      "primary": {
        "html": "<button class=\"inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm text-primary-foreground shadow-sm hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring h-9\">Label</button>",
        "height": "36px",
        "radius": "6px",
        "padding": "8px 16px"
      },
      "outline": {
        "html": "<button class=\"inline-flex items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm hover:bg-accent hover:text-accent-foreground h-9\">Label</button>",
        "height": "36px",
        "radius": "6px",
        "padding": "8px 16px"
      },
      "ghost": {
        "html": "<button class=\"inline-flex items-center justify-center rounded-md px-3 py-2 text-sm hover:bg-muted hover:text-foreground h-9\">Label</button>",
        "height": "36px",
        "radius": "6px",
        "padding": "8px 12px"
      },
      "destructive": {
        "html": "<button class=\"inline-flex items-center justify-center rounded-md bg-destructive px-4 py-2 text-sm text-destructive-foreground shadow-sm hover:bg-destructive/90 h-9\">Delete</button>",
        "height": "36px",
        "radius": "6px"
      },
      "icon": {
        "html": "<button class=\"inline-flex items-center justify-center rounded-md hover:bg-muted h-9 w-9\" aria-label=\"Action description\"><svg class=\"h-4 w-4\" /></button>",
        "size": "36x36"
      }
    },
    "badge": {
      "default": {
        "html": "<span class=\"inline-flex items-center rounded-full bg-primary px-2.5 py-0.5 text-xs font-semibold text-primary-foreground\">Label</span>",
        "radius": "9999px"
      },
      "secondary": {
        "html": "<span class=\"inline-flex items-center rounded-full bg-secondary px-2.5 py-0.5 text-xs font-semibold text-secondary-foreground\">Label</span>",
        "radius": "9999px"
      },
      "outline": {
        "html": "<span class=\"inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold text-foreground\">Label</span>",
        "radius": "9999px"
      }
    },
    "card": {
      "default": {
        "html": "<div class=\"rounded-lg border border-border bg-card p-6 shadow-sm\"><h3 class=\"font-heading text-base font-semibold\">Title</h3><p class=\"text-sm text-muted-foreground\">Description</p></div>",
        "radius": "8px",
        "padding": "24px"
      }
    },
    "input": {
      "default": {
        "html": "<input class=\"flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50\" />",
        "height": "36px",
        "radius": "6px"
      }
    },
    "table": {
      "header": {
        "css": "bg-muted/50 font-semibold text-muted-foreground text-xs"
      },
      "row": {
        "css": "border-b border-border hover:bg-muted/50 transition-colors"
      },
      "cell": {
        "css": "text-sm font-normal py-3 px-4"
      }
    }
  },
  "cssVariables": {
    "light": {
      "--background": "0 0% 100%",
      "--foreground": "224 71.4% 4.1%",
      "--card": "0 0% 100%",
      "--card-foreground": "224 71.4% 4.1%",
      "--popover": "0 0% 100%",
      "--popover-foreground": "224 71.4% 4.1%",
      "--primary": "221 83% 53%",
      "--primary-foreground": "0 0% 100%",
      "--secondary": "214 95% 93%",
      "--secondary-foreground": "221 83% 40%",
      "--muted": "220 14.3% 95.9%",
      "--muted-foreground": "220 8.9% 46.1%",
      "--accent": "214 95% 93%",
      "--accent-foreground": "221 83% 40%",
      "--destructive": "0 84.2% 60.2%",
      "--destructive-foreground": "210 20% 98%",
      "--border": "220 13% 91%",
      "--input": "220 13% 91%",
      "--ring": "221 83% 53%",
      "--radius": "0.5rem",
      "--success": "160 84% 39%",
      "--warning": "38 92% 50%",
      "--selected": "215 20% 88%",
      "--selected-foreground": "215 28% 17%",
      "--tech-bg": "0 0% 98%",
      "--container-bg": "0 0% 100%",
      "--sidebar-background": "0 0% 100%",
      "--sidebar-foreground": "240 5.3% 26.1%",
      "--sidebar-primary": "240 5.9% 10%",
      "--sidebar-primary-foreground": "0 0% 98%",
      "--sidebar-accent": "215 20% 88%",
      "--sidebar-accent-foreground": "215 28% 17%",
      "--sidebar-border": "220 13% 91%",
      "--sidebar-ring": "217.2 91.2% 59.8%",
      "--chart-1": "12 76% 61%",
      "--chart-2": "173 58% 39%",
      "--chart-3": "197 37% 24%",
      "--chart-4": "43 74% 66%",
      "--chart-5": "27 87% 67%"
    },
    "dark": {
      "--background": "224 71.4% 4.1%",
      "--foreground": "210 20% 98%",
      "--card": "224 71.4% 4.1%",
      "--card-foreground": "210 20% 98%",
      "--popover": "224 71.4% 4.1%",
      "--popover-foreground": "210 20% 98%",
      "--primary": "213 97% 87%",
      "--primary-foreground": "221 83% 20%",
      "--secondary": "215 27.9% 16.9%",
