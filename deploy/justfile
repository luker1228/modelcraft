set shell := ["bash", "-cu"]

COMPOSE_FILE := "compose/docker-compose.local.yml"
COMPOSE := `if docker compose version >/dev/null 2>&1; then echo "docker compose"; else echo "docker-compose"; fi`
MYSQL_ENV_FILE := "env/mysql.local.env"
SCHEMA_DIR := "../modelcraft-backend/db/schema/mysql"

_default:
    @just --list

# Build and start all local deploy services
deploy:
    {{COMPOSE}} -f {{COMPOSE_FILE}} up -d --build

# Start all local deploy services without rebuilding
up:
    {{COMPOSE}} -f {{COMPOSE_FILE}} up -d

# Stop and remove local deploy containers
down:
    {{COMPOSE}} -f {{COMPOSE_FILE}} down

# Show local deploy service status
ps:
    {{COMPOSE}} -f {{COMPOSE_FILE}} ps

# Follow logs for all local deploy services
logs:
    {{COMPOSE}} -f {{COMPOSE_FILE}} logs -f

# Restart all local deploy services
restart:
    {{COMPOSE}} -f {{COMPOSE_FILE}} restart

# Stop containers and remove volumes. This clears MySQL data.
clean:
    {{COMPOSE}} -f {{COMPOSE_FILE}} down -v

# Build and restart backend service
backend:
    {{COMPOSE}} -f {{COMPOSE_FILE}} up -d --build backend

# Build and restart frontend service
frontend:
    {{COMPOSE}} -f {{COMPOSE_FILE}} up -d --build frontend

# Build and restart agent service
agent:
    {{COMPOSE}} -f {{COMPOSE_FILE}} up -d --build modelcraft-agent

# Restart APISIX service
apisix:
    {{COMPOSE}} -f {{COMPOSE_FILE}} restart apisix

# Start tools profile services
tools:
    {{COMPOSE}} -f {{COMPOSE_FILE}} --profile tools up -d

# Apply backend MySQL schema to the local deploy database via Atlas
db-up:
    #!/usr/bin/env bash
    set -euo pipefail

    if ! command -v atlas >/dev/null 2>&1; then
        echo "atlas 未安装，请先安装 atlas CLI"
        exit 1
    fi

    if [ ! -f "{{MYSQL_ENV_FILE}}" ]; then
        echo "找不到 MySQL 配置文件: {{MYSQL_ENV_FILE}}"
        exit 1
    fi

    if [ ! -d "{{SCHEMA_DIR}}" ]; then
        echo "找不到 schema 目录: {{SCHEMA_DIR}}"
        exit 1
    fi

    set -a
    source "{{MYSQL_ENV_FILE}}"
    set +a

    DB_HOST="127.0.0.1"
    DB_PORT="6033"
    DB_NAME="${MYSQL_DATABASE:-modelcraft}"
    DB_USER="root"
    DB_PASSWORD="${MYSQL_ROOT_PASSWORD}"
    DB_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"
    DB_DEV_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}_dev"

    if [ -z "${DB_PASSWORD}" ]; then
        echo "MYSQL_ROOT_PASSWORD 未设置，无法连接数据库"
        exit 1
    fi

    mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" \
        -e "CREATE DATABASE IF NOT EXISTS \`${DB_NAME}\`; CREATE DATABASE IF NOT EXISTS \`${DB_NAME}_dev\`;"

    echo "🗄️  Applying schema with Atlas..."
    echo "   - DB_URL: ${DB_URL}"
    echo "   - Schema Dir: {{SCHEMA_DIR}}"

    atlas schema apply -u "${DB_URL}" --to "file://{{SCHEMA_DIR}}/" --dev-url "${DB_DEV_URL}" --auto-approve

# Drop and recreate local deploy MySQL databases
db-reset:
    #!/usr/bin/env bash
    set -euo pipefail

    if [ ! -f "{{MYSQL_ENV_FILE}}" ]; then
        echo "找不到 MySQL 配置文件: {{MYSQL_ENV_FILE}}"
        exit 1
    fi

    set -a
    source "{{MYSQL_ENV_FILE}}"
    set +a

    DB_HOST="127.0.0.1"
    DB_PORT="6033"
    DB_NAME="${MYSQL_DATABASE:-modelcraft}"
    DB_DEV_NAME="${DB_NAME}_dev"
    DB_USER="root"
    DB_PASSWORD="${MYSQL_ROOT_PASSWORD}"

    if [ -z "${DB_PASSWORD}" ]; then
        echo "MYSQL_ROOT_PASSWORD 未设置，无法连接数据库"
        exit 1
    fi

    echo "Resetting databases: ${DB_NAME}, ${DB_DEV_NAME}"
    mysql -h "${DB_HOST}" -P "${DB_PORT}" -u "${DB_USER}" "-p${DB_PASSWORD}" \
        -e "DROP DATABASE IF EXISTS ${DB_NAME}; DROP DATABASE IF EXISTS ${DB_DEV_NAME}; CREATE DATABASE ${DB_NAME}; CREATE DATABASE ${DB_DEV_NAME};"
