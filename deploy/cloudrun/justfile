# 云托管部署便利命令
set shell := ["bash", "-cu"]

# APISIX 构建上下文目录（需要先复制 apisix 配置）
APISIX_CTX := "apisix"

_default:
    @just --list

# 复制 apisix 配置到构建上下文
cp-apisix-config:
    cp ../../apisix/config.yaml {{APISIX_CTX}}/config.yaml
    cp ../../apisix/apisix.yaml {{APISIX_CTX}}/apisix.yaml
    @echo "✅ APISIX 配置已复制到 deploy/cloudrun/{{APISIX_CTX}}/"

# 本地构建所有镜像
build-all: cp-apisix-config
    cd ../../modelcraft-backend && docker build -t modelcraft-backend:cloudrun .
    cd {{APISIX_CTX}} && docker build -t modelcraft-apisix:cloudrun .
    cd ../../modelcraft-front && docker build -t modelcraft-frontend:cloudrun .
    cd ../../modelcraft-agent && docker build -t modelcraft-agent:cloudrun .
    @echo "✅ 所有镜像构建完成"

# 本地构建 backend 镜像
build-backend:
    cd ../../modelcraft-backend && docker build -t modelcraft-backend:cloudrun .

# 本地构建 apisix 镜像
build-apisix: cp-apisix-config
    cd {{APISIX_CTX}} && docker build -t modelcraft-apisix:cloudrun .

# 本地构建 frontend 镜像
build-frontend:
    cd ../../modelcraft-front && docker build -t modelcraft-frontend:cloudrun .

# 本地构建 agent 镜像
build-agent:
    cd ../../modelcraft-agent && docker build -t modelcraft-agent:cloudrun .

# 清理 APISIX 构建上下文中的配置文件
clean-apisix-config:
    rm -f {{APISIX_CTX}}/config.yaml {{APISIX_CTX}}/apisix.yaml
    @echo "✅ 已清理"
