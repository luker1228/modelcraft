# ═══════════════════════════════════════════════════════════════════
# Backend 云托管环境变量
# 在微信云托管控制台「服务配置 → 环境变量」中逐条添加
# ═══════════════════════════════════════════════════════════════════

# ── 端口（云托管自动注入 PORT=80，无需手动设置） ──
# PORT=80

# ── 运行模式 ──
GIN_MODE=release

# ── 数据库（自建 MySQL，替换为实际 IP:Port） ──
DB_HOST=<your-mysql-host>
DB_PORT=3306
DB_USERNAME=modelcraft
DB_PASSWORD=<your-mysql-password>
DB_DATABASE=modelcraft
DB_MIGRATE_ON_STARTUP=true

# ── Redis（可选，当前服务暂不依赖） ──
# REDIS_HOST=<your-redis-host>
# REDIS_PORT=6379
# REDIS_PASSWORD=<your-redis-password>

# ── JWT ──
JWT_SECRET=<generate-random-64-char-string>
JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
<your-ec-private-key>
-----END EC PRIVATE KEY-----"
JWT_ISSUER=modelcraft
JWT_EXPIRATION=21600s

# ── 加密 ──
CRYPTO_AES_KEY=<generate-32-byte-hex-string>

# ── 认证 ──
INTERNAL_TOKEN=<generate-random-token>
AUTH_DESIGN_ENABLED=true
AUTH_RUNTIME_ENABLED=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax

# ── 日志 ──
LOG_LEVEL=info
LOG_OUTPUT_PATH=stdout
