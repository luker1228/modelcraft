# ═══════════════════════════════════════════════════════════════════
# APISIX Gateway 云托管环境变量
# ═══════════════════════════════════════════════════════════════════

# ── 端口（云托管自动注入 PORT=80） ──
# PORT=80

# ── JWT ──
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
<your-ec-public-key>
-----END PUBLIC KEY-----

# ── CORS（替换为云托管前端域名） ──
FRONTEND_URL=<your-cloudrun-frontend-domain>

# ── 观测 ──
# OTEL_EXPORTER_OTLP_ENDPOINT=

TZ=Asia/Shanghai
