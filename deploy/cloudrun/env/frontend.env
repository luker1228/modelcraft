# ═══════════════════════════════════════════════════════════════════
# Frontend 云托管环境变量
# ═══════════════════════════════════════════════════════════════════

# ── 端口（云托管自动注入 PORT=80） ──
# PORT=80

# ── 运行环境 ──
NODE_ENV=production
TZ=Asia/Shanghai

# ── 后端地址（指向 APISIX 云托管服务内网域名） ──
# 云托管内网访问格式：http://<service-name>:80
# 或者使用云托管分配的完整域名
BACKEND_URL=http://apisix:80
