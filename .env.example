# ModelCraft 本地 Docker 部署环境变量
# 复制此文件为 .env 并填写必填项
#
# 快速生成安全密钥：
#   DB_PASSWORD:    openssl rand -base64 24
#   JWT_SECRET:     openssl rand -base64 64
#   CRYPTO_AES_KEY: openssl rand -hex 16   (必须 32 字节)
#   INTERNAL_TOKEN: openssl rand -hex 16
#   JWT 密钥对:     见下方说明

# ============================================================
# 数据库
# ============================================================
DB_USERNAME=modelcraft
DB_PASSWORD=modelcraft_local_pass    # REQUIRED: 修改为强密码
DB_DATABASE=modelcraft
MYSQL_PORT=6033                      # 宿主机映射端口（避免与本地 3306 冲突）

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=redis123
REDIS_PORT_HOST=6379

# ============================================================
# 安全密钥（REQUIRED）
# ============================================================

# JWT HMAC 密钥（Backend 和 Gateway 共享）
JWT_SECRET=modelcraft_dev_secret_please_change_in_production

# AES-256 加密密钥（必须 32 字节）
CRYPTO_AES_KEY=12345678901234567890123456789012

# BFF → Backend 内部通信令牌
INTERNAL_TOKEN=test-internal-token-for-bdd

# JWT ES256 私钥（Backend 签发 Token）
# 生成：openssl ecparam -name prime256v1 -genkey -noout -out ec_private.pem
JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
MHcCAQEEIKDDrR2NGbLrNf9Ap2TTF0jIlwSx7ExEiCsF5Z0N4y4AoAoGCCqGSM49
AwEHoUQDQgAEw1SV3/9qLTugs2eF1dw963KpTNtktbdCtuciyI3OJ01MclvPTFE/
Thqti3TegWLdaxidmpPQ5pemawUXIqu6Yg==
-----END EC PRIVATE KEY-----"

# JWT ES256 公钥（Gateway 验证 Token）
# 生成：openssl ec -in ec_private.pem -pubout -out ec_public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAEw1SV3/9qLTugs2eF1dw963KpTNtk
tbdCtuciyI3OJ01MclvPTFE/Thqti3TegWLdaxidmpPQ5pemawUXIqu6Yg==
-----END PUBLIC KEY-----"

# ============================================================
# 端口配置（可选，按需修改避免冲突）
# ============================================================
BACKEND_PORT=8080
GATEWAY_PORT=9080
FRONTEND_PORT=3000

# ============================================================
# APISIX Gateway (replaces modelcraft-gateway)
# ============================================================
# GATEWAY_PORT=9080
# JWT_PUBLIC_KEY is shared with backend — already defined above
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Backend Cookie config (effective after APISIX migration)
AUTH_COOKIE_SECURE=false    # set to true in production
AUTH_COOKIE_DOMAIN=         # leave empty to use request host
AUTH_COOKIE_SAME_SITE=strict

# ============================================================
# 其他
# ============================================================
GIN_MODE=release
LOGGER_LEVEL=info
DB_MIGRATE_ON_STARTUP=true
FRONTEND_URL=http://localhost:3000

# ============================================================
# modelcraft-agent
# ============================================================
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
AGENT_PORT=8000
