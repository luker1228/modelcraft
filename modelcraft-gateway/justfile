# justfile - ModelCraft Gateway 命令运行器

set dotenv-load
set shell := ["bash", "-cu"]

BINARY_NAME := "modelcraft-gateway"
SERVER_PATH  := "./cmd/gateway"
GATEWAY_PORT := "8090"

# ========================
# 🚀 开发
# ========================

# 显示所有可用命令
default:
    @just --list

# 本地运行（需要 .env 文件）。Use --force to stop existing processes first.
[doc("Run the gateway in background. Use --force or force=true to stop existing processes first")]
run *FLAGS:
    #!/usr/bin/env bash
    FORCE_MODE=false
    for arg in {{FLAGS}}; do
        if [ "$arg" = "--force" ] || [ "$arg" = "force=true" ]; then
            FORCE_MODE=true
            break
        fi
    done

    if [ "$FORCE_MODE" = "true" ]; then
        echo "🔪 Force mode: Stopping existing processes..."
        if lsof -ti:{{GATEWAY_PORT}} > /dev/null 2>&1; then
            lsof -ti:{{GATEWAY_PORT}} | xargs kill -9 2>/dev/null || fuser -k {{GATEWAY_PORT}}/tcp 2>/dev/null
            echo "✅ Stopped process on port {{GATEWAY_PORT}}"
        fi
        if pgrep -f "go run.*cmd/gateway" > /dev/null; then
            pkill -9 -f "go run.*cmd/gateway"
            echo "✅ Stopped go run processes"
        fi
        pkill -f "^{{BINARY_NAME}}" 2>/dev/null && echo "✅ Stopped {{BINARY_NAME}} binary" || true
        sleep 1
    fi

    echo "🚀 Starting gateway..."
    mkdir -p logs
    echo "📝 Log output: logs/server.log"
    nohup sh -c "LOG_OUTPUT_PATH=logs/server.log go run {{SERVER_PATH}}/..." > logs/server.log 2>&1 &
    PID=$!
    sleep 2
    if kill -0 $PID 2>/dev/null; then
        echo "✅ Gateway started in background"
        echo "   PID: $PID"
        echo "   Logs: tail -f logs/server.log"
        echo "   Or use: just logs"
    else
        echo "❌ Gateway failed to start. Check logs/server.log"
        exit 1
    fi

# 查看实时日志
logs:
    tail -f logs/server.log

# 停止网关
stop:
    #!/usr/bin/env bash
    if lsof -ti:{{GATEWAY_PORT}} > /dev/null 2>&1; then
        lsof -ti:{{GATEWAY_PORT}} | xargs kill -9 2>/dev/null || true
        echo "✅ Stopped gateway on port {{GATEWAY_PORT}}"
    else
        echo "ℹ️  No gateway process on port {{GATEWAY_PORT}}"
    fi

# 重启网关
restart:
    just stop
    sleep 1
    just run

# 编译二进制
build:
    go build -o bin/{{BINARY_NAME}} {{SERVER_PATH}}/...

# ========================
# 🔍 代码质量
# ========================

# 运行所有测试
test:
    go test ./...

# 格式化代码
fmt:
    gofumpt -w .

# 静态检查（需要安装 golangci-lint）
lint:
    golangci-lint run

# 自动修复可修复的 lint 问题
lint-fix:
    golangci-lint run --fix

# ========================
# 🛠️ 依赖管理
# ========================

# 拉取依赖
tidy:
    go mod tidy

# 验证依赖
verify:
    go mod verify
